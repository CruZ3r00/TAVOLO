# Server
HOST=0.0.0.0
PORT=1337

# Secrets
APP_KEYS=toBeModified1,toBeModified2,toBeModified3,toBeModified4
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified

# Database Configuration
DATABASE_CLIENT=mysql
DATABASE_NAME=cms-restaurants
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_USERNAME=cms-admin
DATABASE_PASSWORD=tobemodified
DATABASE_SSL=false
DATABASE_FILENAME=

# CORS
# Lista CSV di origini autorizzate, es. https://app.example.com,https://admin.example.com
# In LAN aggiungi l'IP della macchina che ospita Vite, es. http://192.168.1.63:5174
CORS_ORIGIN=http://localhost:5174,http://127.0.0.1:5174,http://192.168.1.63:5174
# Crea automaticamente <Ristorante>.cameriere e <Ristorante>.cucina alla registrazione.
REGISTER_AUTO_STAFF_ACCOUNTS=true
# Impostare true solo dietro un reverse proxy fidato che valorizza X-Forwarded-For.
TRUST_PROXY=false

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tobemodified
SMTP_PASS=tobemodified
SMTP_DEFAULT_FROM=no-reply@example.com
SMTP_DEFAULT_REPLY_TO=support@example.com
NEW_USER_NOTIFICATION_EMAIL=

# Seed demo
SEED_DEMO_DATA=false
DEMO_USER_EMAIL=demo@restaurant.com
DEMO_USER_PASSWORD=tobemodified

# OCR pipeline (microservizio Python locale)
# URL base del microservizio OCR. Il microservizio deve essere avviato prima di Strapi.
OCR_SERVICE_URL=http://127.0.0.1:8001
# Timeout HTTP Strapi -> microservizio (ms). Deve essere >= OLLAMA_TIMEOUT_SECONDS*1000 del microservizio.
OCR_SERVICE_TIMEOUT_MS=180000
# Shared secret opzionale per proteggere il microservizio (header X-Internal-Token). Lasciare vuoto in dev.
OCR_SERVICE_INTERNAL_TOKEN=
# In produzione lasciare true e valorizzare OCR_SERVICE_INTERNAL_TOKEN.
OCR_SERVICE_INTERNAL_TOKEN_REQUIRED=true

# Upload menu (analyzeImport)
# Cartella su disco dove Strapi salva i file caricati per l'OCR. Default: <strapi_root>/.menu-upload
# Deve essere leggibile dal microservizio OCR (stesso host o filesystem condiviso).
MENU_UPLOAD_DIR=
# Dimensione massima file uploadato in byte. Default 20MB.
MENU_UPLOAD_MAX_BYTES=20971520

# Reservations
SUMMER_MONTHS=4,5,6,7,8,9,10
RESERVATION_SLOT_MINUTES=120
PUBLIC_RESERVATIONS_ENFORCE_CAPACITY=true
RESERVATION_RATE_LIMIT_WINDOW_MS=600000
RESERVATION_RATE_LIMIT_MAX=5

# Payment service (orders)
# Strategy di default: simulator | pos | fiscal_register
PAYMENT_STRATEGY=simulator
# Latenza simulata in ms (solo per strategy "simulator")
PAYMENT_SIMULATOR_LATENCY_MS=200
# Probabilita di fallimento simulato 0..1 (solo per strategy "simulator", default 0 = mai)
PAYMENT_SIMULATOR_FAILURE_RATE=0

# Stripe Billing (abbonamento SaaS)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
FRONTEND_URL=http://localhost:5174

# ─────────────────────────────────────────────────────────────────────────
# ⚠️  NUOVE VARIABILI (introdotte 2026-04-27, Fase 2 pos-rt-service)
# Aggiungere queste righe al .env reale. Se lasciate vuote → APNs disabilitato
# graziosamente: Strapi continua a funzionare, l'app iOS riceve i job solo
# tramite WebSocket (quando in foreground) o polling al riavvio. Push silent
# wake-up disponibile solo se TUTTE le 4 variabili `APNS_*` sono valorizzate.
# ─────────────────────────────────────────────────────────────────────────

# APNs (Apple Push Notification service) — richiesto per silent push wake-up
# dell'app iOS pos-rt-service quando è in background. Senza queste variabili
# l'app iOS funziona ma il polling è meno reattivo (max ~10s vs <2s con APNs).
#
# COME OTTENERE QUESTI VALORI (in produzione):
#
# 1. Vai su https://developer.apple.com/account/resources/authkeys/list
# 2. Click "+" per creare una nuova "APNs Authentication Key"
# 3. Spunta "Apple Push Notifications service (APNs)" → Continue → Register
# 4. SCARICA il file .p8 (puoi scaricarlo UNA SOLA VOLTA — conservalo)
# 5. Annota il "Key ID" (10 char alfanumerico, mostrato in pagina) → APNS_KEY_ID
# 6. Apri https://developer.apple.com/account → in alto a destra c'è il "Team ID"
#    (10 char, es. "ABCDE12345") → APNS_TEAM_ID
# 7. Bundle ID dell'app iOS che pubblicherai sullo store (es. "it.tuodominio.posrt")
#    → APNS_BUNDLE_ID. Deve coincidere col bundle id configurato in Xcode.
# 8. Carica il .p8 sul server di produzione (path assoluto, permessi 0600)
#    e mettilo in APNS_KEY_PATH.
# 9. APNS_PRODUCTION=true SOLO con app firmata Distribution e installata da
#    App Store / TestFlight. Per dev (Xcode debug build su device fisico)
#    lasciare APNS_PRODUCTION=false.

# Path assoluto al file .p8 (es. /etc/strapi/apns/AuthKey_ABCDE12345.p8).
# Permessi consigliati: chown <strapi-user>:<strapi-group>, chmod 0600.
APNS_KEY_PATH=
# Key ID dell'APNs Authentication Key (10 char, dalla console Apple).
APNS_KEY_ID=
# Team ID dell'account Apple Developer (10 char, in alto a destra nella console).
APNS_TEAM_ID=
# Bundle id dell'app iOS pos-rt-service (es. it.tuodominio.posrt).
# DEVE corrispondere a quello configurato in Xcode/App Store Connect.
APNS_BUNDLE_ID=
# APNs endpoint:
#   - false → sandbox (api.development.push.apple.com), per build dev/Xcode
#   - true  → production (api.push.apple.com), per build TestFlight + App Store
# Mismatch fra build dell'app e questo flag → push silenziosamente droppati.
APNS_PRODUCTION=false

# pos-rt-service polling defaults (default ragionevoli, modificare solo se
# si verificano problemi di carico / batteria / latenza).
# Lato server, l'app/desktop chiede questi valori con GET /pos-devices/me/config.
# Override server-side, NON impostazione client-side.
#
# Intervallo polling quando il WS è connesso (Windows/Android desktop):
# tipicamente alto perché WS notifica già in tempo reale. Default 60s.
POS_POLL_INTERVAL_CONNECTED_S=60
# Intervallo polling quando il WS NON è connesso (mobile background, WS down):
# default 10s = compromesso reattività/batteria. Su iOS in background il
# polling viene comunque triggerato da APNs silent push, qui è il fallback.
POS_POLL_INTERVAL_DISCONNECTED_S=10
# Frequenza heartbeat (last_seen update). Default 30s.
POS_HEARTBEAT_INTERVAL_S=30

# ─────────────────────────────────────────────────────────────────────────
# ⚠️  NUOVE VARIABILI (Fase 5 — installer/store URLs)
# Mostrate dalla pagina profilo Vue → "Configura POS/Cassa fiscale".
# Se vuote → frontend mostra "presto disponibile" e nasconde i bottoni.
# ─────────────────────────────────────────────────────────────────────────

# Versione corrente del pos-rt-service (mostrata nelle download card).
POS_RT_SERVICE_VERSION=1.0.0

# URL diretti agli installer/app. In produzione punteranno a un CDN o a
# Strapi public/downloads/. In dev locale si possono mettere file in
# strapi/public/downloads/ per testare il flow.
#
# Windows MSI installer (auto-update + servizio Windows). Riempi quando
# hai buildato `pos-rt-service` con `pkg + WiX` (vedi installer/windows/).
POS_INSTALLER_WINDOWS_MSI=
# Linux AppImage (build con pkg + appimagetool).
POS_INSTALLER_LINUX_APPIMAGE=
# macOS DMG (build con pkg + create-dmg, signing Apple Developer).
POS_INSTALLER_MACOS_DMG=
# APK Android sideload (utile per device dedicati Sunmi/PAX o test interni).
POS_ANDROID_APK=

# URL store pubblici (riempi dopo submit/approvazione).
POS_ANDROID_PLAY_URL=
POS_IOS_APPSTORE_URL=

# URL guida setup (markdown, anche su GitHub o sito esterno).
POS_DOCS_URL=
