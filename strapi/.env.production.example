# Tavolo Strapi production env
# Copy this file to .env on the server and replace every <...> value.

NODE_ENV=production
HOST=0.0.0.0
PORT=1337
PUBLIC_URL=https://api.comfortables.eu
FRONTEND_URL=https://app.comfortables.eu
SITE_BASE_URL=https://api.comfortables.eu

# Security secrets: generate fresh random values for the server.
APP_KEYS=<random-1>,<random-2>,<random-3>,<random-4>
API_TOKEN_SALT=<random-token-salt>
ADMIN_JWT_SECRET=<random-admin-jwt-secret>
TRANSFER_TOKEN_SALT=<random-transfer-token-salt>
JWT_SECRET=<random-jwt-secret>

# CORS / proxy
CORS_ORIGIN=https://app.comfortables.eu
FRAME_ANCESTORS=https://app.comfortables.eu
TRUST_PROXY=true

# Database
DATABASE_CLIENT=postgres
DATABASE_HOST=<database-host>
DATABASE_PORT=5432
DATABASE_NAME=<database-name>
DATABASE_USERNAME=<database-user>
DATABASE_PASSWORD=<database-password>
DATABASE_SCHEMA=public
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=true
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Email via Resend SMTP
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=resend
SMTP_PASS=<resend-api-key>
SMTP_DEFAULT_FROM=Tavolo <no-reply@app.comfortables.eu>
SMTP_DEFAULT_REPLY_TO=support@app.comfortables.eu
NEW_USER_NOTIFICATION_EMAIL=

# Registration / seed
REGISTER_AUTO_STAFF_ACCOUNTS=true
SEED_DEMO_DATA=false

# OCR pipeline.
# This is the OCR microservice URL, not the raw Ollama URL.
OCR_SERVICE_URL=http://127.0.0.1:8001
OCR_SERVICE_TIMEOUT_MS=180000
OCR_SERVICE_INTERNAL_TOKEN_REQUIRED=true
OCR_SERVICE_INTERNAL_TOKEN=<shared-random-token>
MENU_UPLOAD_DIR=/var/lib/tavolo/menu-upload
MENU_UPLOAD_MAX_BYTES=20971520

# Reservations
SUMMER_MONTHS=4,5,6,7,8,9,10
RESERVATION_SLOT_MINUTES=120
PUBLIC_RESERVATIONS_ENFORCE_CAPACITY=true
RESERVATION_RATE_LIMIT_WINDOW_MS=600000
RESERVATION_RATE_LIMIT_MAX=5

# Stripe live billing
STRIPE_SECRET_KEY=sk_live_<...>
STRIPE_WEBHOOK_SECRET=whsec_<...>
STRIPE_PRICE_STARTER=price_<starter-live>
STRIPE_PRICE_PRO=price_<pro-live>

# Payment service
PAYMENT_STRATEGY=simulator
PAYMENT_SIMULATOR_LATENCY_MS=200
PAYMENT_SIMULATOR_FAILURE_RATE=0

# APNs / POS RT optional production values
APNS_KEY_PATH=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
APNS_PRODUCTION=true
POS_POLL_INTERVAL_CONNECTED_S=60
POS_POLL_INTERVAL_DISCONNECTED_S=10
POS_HEARTBEAT_INTERVAL_S=30
POS_RT_SERVICE_VERSION=1.0.0
POS_INSTALLER_WINDOWS_MSI=
POS_INSTALLER_LINUX_APPIMAGE=
POS_INSTALLER_MACOS_DMG=
POS_ANDROID_APK=
POS_ANDROID_APK_PATH=
POS_ANDROID_PLAY_URL=
POS_IOS_APPSTORE_URL=
POS_DOCS_URL=
