{
  "kind": "collectionType",
  "collectionName": "order_archives",
  "info": {
    "singularName": "order-archive",
    "pluralName": "order-archives",
    "displayName": "OrderArchive",
    "description": "Snapshot immutabile di un ordine chiuso per storico e analytics"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "order_document_id": {
      "type": "string",
      "required": true,
      "maxLength": 64
    },
    "reservation_document_id": {
      "type": "string",
      "required": false,
      "maxLength": 64
    },
    "opened_at": {
      "type": "datetime",
      "required": true
    },
    "closed_at": {
      "type": "datetime",
      "required": true
    },
    "duration_minutes": {
      "type": "integer",
      "required": false,
      "min": 0
    },
    "customer_name": {
      "type": "string",
      "required": false,
      "maxLength": 120
    },
    "covers": {
      "type": "integer",
      "required": false,
      "min": 1,
      "max": 1000
    },
    "is_walkin": {
      "type": "boolean",
      "default": false,
      "required": false
    },
    "table_number": {
      "type": "integer",
      "required": false
    },
    "table_area": {
      "type": "string",
      "required": false,
      "maxLength": 32
    },
    "total_amount": {
      "type": "decimal",
      "required": true,
      "default": 0
    },
    "payment_method": {
      "type": "string",
      "required": false,
      "maxLength": 64
    },
    "payment_reference": {
      "type": "string",
      "required": false,
      "maxLength": 255
    },
    "items_json": {
      "type": "json",
      "required": true
    },
    "items_count": {
      "type": "integer",
      "required": false,
      "min": 0
    },
    "fk_user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    }
  }
}
