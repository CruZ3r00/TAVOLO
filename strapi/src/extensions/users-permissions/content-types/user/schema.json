{
  "kind": "collectionType",
  "collectionName": "up_users",
  "info": {
    "name": "user",
    "description": "",
    "singularName": "user",
    "pluralName": "users",
    "displayName": "User"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "username": {
      "type": "string",
      "minLength": 3,
      "unique": true,
      "configurable": false,
      "required": true
    },
    "email": {
      "type": "email",
      "minLength": 6,
      "configurable": false,
      "required": true
    },
    "provider": {
      "type": "string",
      "configurable": false
    },
    "password": {
      "type": "password",
      "minLength": 6,
      "configurable": false,
      "private": true,
      "searchable": false
    },
    "resetPasswordToken": {
      "type": "string",
      "configurable": false,
      "private": true,
      "searchable": false
    },
    "confirmationToken": {
      "type": "string",
      "configurable": false,
      "private": true,
      "searchable": false
    },
    "confirmed": {
      "type": "boolean",
      "default": false,
      "configurable": false
    },
    "blocked": {
      "type": "boolean",
      "default": false,
      "configurable": false
    },
    "role": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.role",
      "inversedBy": "users",
      "configurable": false
    },
    "name": {
      "type": "string",
      "required": true
    },
    "surname": {
      "type": "string",
      "required": true
    },
    "payment_method": {
      "type": "json",
      "required": false
    },
    "stripe_customer_id": {
      "type": "string",
      "private": true
    },
    "stripe_subscription_id": {
      "type": "string",
      "private": true
    },
    "subscription_status": {
      "type": "string"
    },
    "subscription_plan": {
      "type": "string"
    },
    "subscription_current_period_end": {
      "type": "datetime"
    },
    "subscription_cancel_at_period_end": {
      "type": "boolean",
      "default": false
    },
    "fk_prefs": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::preference.preference"
    },
    "end_subscription": {
      "type": "date"
    },
    "birth_date": {
      "type": "date"
    },
    "url": {
      "type": "string"
    },
    "staff_role": {
      "type": "enumeration",
      "enum": [
        "owner",
        "gestione",
        "cameriere",
        "cucina",
        "bar",
        "pizzeria",
        "cucina_sg"
      ],
      "default": "owner"
    },
    "fk_owner": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "staff_members"
    },
    "staff_members": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "plugin::users-permissions.user",
      "mappedBy": "fk_owner"
    },
    "two_factor_secret": {
      "type": "string",
      "private": true,
      "searchable": false
    },
    "two_factor_enabled": {
      "type": "boolean",
      "default": false
    },
    "two_factor_recovery_codes": {
      "type": "json",
      "private": true
    },
    "unavailable_ingredients": {
      "type": "json"
    },
    "address": {
      "type": "string"
    },
    "city": {
      "type": "string"
    },
    "cap": {
      "type": "string"
    },
    "province": {
      "type": "string"
    },
    "vat": {
      "type": "string"
    }
  }
}
