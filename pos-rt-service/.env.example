# pos-rt-service — Esempio file environment
# Copia in .env per overrides locali (dev).
# In produzione le configurazioni live sono nel DB locale (tabella config/secrets).

# --- Generali ---
# Livello log: trace, debug, info, warn, error, fatal
LOG_LEVEL=info
# Cartella dati: se non impostata, usa path OS-specific (vedi src/utils/machine.js)
# APP_DATA_DIR=/var/lib/pos-rt-service

# --- API locale ---
# Porta API admin. Se 0, viene allocata dinamicamente al primo avvio e salvata in config.
LOCAL_API_PORT=0
# Bind obbligatorio: 127.0.0.1
LOCAL_API_HOST=127.0.0.1

# --- Pairing ---
# Quando true, l'endpoint /pair rimane abilitato anche se esiste un device (solo dev!)
ALLOW_RE_PAIR=false

# --- Connessione a Strapi (override DB) ---
# STRAPI_URL=https://api.example.com
# STRAPI_WS_URL=wss://api.example.com/ws/pos
# Device token in chiaro (solo dev; in prod è cifrato nel DB):
# DEVICE_TOKEN=

# --- TLS ---
# Consente connessioni http:// a Strapi (solo dev)
ALLOW_INSECURE=false
# Elenco fingerprint SHA256 cert attesi, separati da virgola (cert pinning opzionale)
# TRUSTED_CERT_FINGERPRINTS=

# --- Scheduler ---
# Frequenze in secondi
POLL_INTERVAL_WS_CONNECTED_S=60
POLL_INTERVAL_WS_DISCONNECTED_S=10
HEARTBEAT_INTERVAL_S=30
WS_RECONNECT_CHECK_S=5

# --- Driver ---
# Valori: stub, escpos, epson-fp90
PRINTER_DRIVER=stub
# Valori: stub, sumup
PAYMENT_DRIVER=stub

# Config stub (solo per testing)
STUB_LATENCY_MS=200
STUB_FAILURE_RATE=0

# --- Queue ---
MAX_JOB_ATTEMPTS=6
MAX_QUEUE_SIZE=10000

# --- Audit retention ---
AUDIT_RETENTION_FISCAL_DAYS=3650
AUDIT_RETENTION_TECH_DAYS=365
