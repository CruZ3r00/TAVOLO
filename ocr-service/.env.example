# Bind del server FastAPI/uvicorn. In MVP restare su loopback (127.0.0.1).
HOST=127.0.0.1
PORT=8001

# Ollama (deve essere installato separatamente: https://ollama.com).
# Prima di avviare il microservizio assicurarsi di aver fatto: `ollama pull qwen2.5:7b`
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT_SECONDS=120

# Lingua PaddleOCR (es. it, en, ch). Scarica modelli dedicati al primo avvio.
OCR_LANG=it
# Toggle GPU (richiede l'installazione di paddlepaddle-gpu al posto di paddlepaddle).
PADDLE_USE_GPU=false
# DPI di rasterizzazione dei PDF tramite PyMuPDF. 300 e' un buon compromesso qualita'/tempo.
PDF_RENDER_DPI=300

# Whitelist path in input. Il microservizio rifiutera' (403) qualsiasi file_path
# che non sia un discendente di questa directory. Deve coincidere con MENU_UPLOAD_DIR di Strapi.
ALLOWED_INPUT_DIR=/home/piocru/Desktop/Projects/cms_restaurant/strapi/.menu-upload

# Shared secret opzionale (header X-Internal-Token). Lasciare vuoto in dev.
INTERNAL_API_TOKEN=
# In produzione impostare true e valorizzare INTERNAL_API_TOKEN.
REQUIRE_INTERNAL_API_TOKEN=false

# Logging: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
