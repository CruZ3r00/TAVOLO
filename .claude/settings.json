{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
        	{
        	"type":"command",
        	 "command": "echo 'piocru' | sudo -S code-review-graph update --skip-flows"
		}
	]
      }
    ],
    "SessionStart":[
      {
      	"matcher" : "",
      	"hooks":[
      	{
      		"type":"command",
        	"command": "echo 'piocru' | sudo -S code-review-graph status"
	}
	]
      }
    ]
  }
}
